# Rebuild thresholded graph and overlay on NYC basemap using Web Mercator projection
edge_weights = (
    janData.groupby(['start_station_name', 'end_station_name'])
           .size()
           .reset_index(name='weight')
)

G = nx.DiGraph()
for _, r in edge_weights.iterrows():
    if r['weight'] > 100:
        G.add_edge(r['start_station_name'], r['end_station_name'], weight=r['weight'])

station_coords = (
    janData[['start_station_name','start_lat','start_lng']]
    .drop_duplicates('start_station_name')
    .set_index('start_station_name')[['start_lng','start_lat']]
    .to_dict('index')
)

# Longitude/latitude to Web Mercator (EPSG:3857) for map alignment
R = 6378137.0
def mercator_xy(lon, lat):
    x = R * np.deg2rad(lon)
    y = R * np.log(np.tan(np.pi/4.0 + np.deg2rad(lat)/2.0))
    return x, y

pos_merc = {}
for n in G.nodes():
    if n in station_coords:
        x, y = mercator_xy(station_coords[n]['start_lng'], station_coords[n]['start_lat'])
        pos_merc[n] = (x, y)

G.remove_edges_from(nx.selfloop_edges(G))

# Basemap bounding box (must match nycmap.png export bounds)
min_lon, max_lon = -74.30, -73.50
min_lat, max_lat =  40.40,  41.10
xmin, ymin = mercator_xy(min_lon, min_lat)
xmax, ymax = mercator_xy(max_lon, max_lat)

# Overlay the directed graph on the NYC basemap
img = mpimg.imread("nycmap.png")
fig, ax = plt.subplots(figsize=(8,10))
ax.imshow(img, extent=[xmin, xmax, ymin, ymax], origin='upper')

edges = list(G.edges(data=True))

nx.draw_networkx_edges(
    G, pos_merc, ax=ax,
    width=2, edge_color='red', alpha=0.18, arrows=False
)
nx.draw_networkx_nodes(
    G, pos_merc, ax=ax,
    node_size=6, node_color='dodgerblue', alpha=0.9, edgecolors='none'
)

ax.set_xlim(xmin, xmax); ax.set_ylim(ymin, ymax)
ax.set_aspect('equal', adjustable='box')
ax.set_title("CitiBike Directed Graph (edges > 100 trips) over NYC Map — Jan 2023")
plt.show()

# Simple networkx position plot as sanity check
pos = {row['start_station_name']: (row['start_lng'], row['start_lat'])
       for _, row in janData.drop_duplicates('start_station_name').iterrows()}
nx.draw(G, pos, node_size=5, alpha=0.6, arrows=False)

import matplotlib.pyplot as plt

# Plot ALL unique station locations (not just thresholded graph nodes)
starts = janData[['start_station_name', 'start_lat', 'start_lng']].rename(
    columns={'start_station_name':'station_name', 'start_lat':'lat', 'start_lng':'lng'}
)
ends = janData[['end_station_name', 'end_lat', 'end_lng']].rename(
    columns={'end_station_name':'station_name', 'end_lat':'lat', 'end_lng':'lng'}
)

stations = (
    pd.concat([starts, ends], ignore_index=True)
      .dropna(subset=['lat', 'lng'])
      .drop_duplicates(subset=['lat', 'lng'])
)

# Filter to NYC coordinate range
stations = stations[
    (stations['lat'].between(40.4, 41.1)) &
    (stations['lng'].between(-74.3, -73.5))
]

plt.figure(figsize=(8, 10))
plt.scatter(stations['lng'], stations['lat'], s=3, alpha=0.6, color='royalblue')
plt.title("CitiBike Station Locations – Jan 2023", fontsize=14)
plt.xlabel("Longitude")
plt.ylabel("Latitude")
plt.axis('equal')
plt.show()

# Station locations overlaid on NYC basemap via Web Mercator
R = 6378137.0
def mercator_xy(lon, lat):
    lon = np.asarray(lon, dtype=float)
    lat = np.asarray(lat, dtype=float)
    x = R * np.deg2rad(lon)
    y = R * np.log(np.tan(np.pi/4.0 + np.deg2rad(lat)/2.0))
    return x, y

x_pts, y_pts = mercator_xy(stations['lng'].values, stations['lat'].values)

min_lon, max_lon = -74.3, -73.5
min_lat, max_lat =  40.4,  41.1
xmin, ymin = mercator_xy(min_lon, min_lat)
xmax, ymax = mercator_xy(max_lon, max_lat)

img = mpimg.imread("nycmap.png")

fig, ax = plt.subplots(figsize=(8,10))
ax.imshow(img, extent=[xmin, xmax, ymin, ymax], origin='upper')
ax.scatter(x_pts, y_pts, s=3, alpha=0.7, color='royalblue')

ax.set_xlim(xmin, xmax); ax.set_ylim(ymin, ymax)
ax.set_aspect('equal', adjustable='box')
ax.set_title("CitiBike Station Locations over NYC Map — Jan 2023")
ax.set_xlabel("Web Mercator X"); ax.set_ylabel("Web Mercator Y")
plt.show()

