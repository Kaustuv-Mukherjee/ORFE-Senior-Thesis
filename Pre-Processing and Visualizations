import pandas as pd
import numpy as np
import matplotlib.image as mpimg

# Explicit dtypes for memory efficiency and column uniformity
dtypes = {
    "ride_id": "string",
    "rideable_type": "category",
    "start_station_name": "string",
    "start_station_id": "string",
    "end_station_name": "string",
    "end_station_id": "string",
    "start_lat": "float64",
    "start_lng": "float64",
    "end_lat": "float64",
    "end_lng": "float64",
    "member_casual": "category"
}
parse_dates = ["started_at", "ended_at"]

# Load and merge the two January 2023 CSV halves
x = pd.read_csv("/content/202301-citibike-tripdata_1.csv",dtype=dtypes,parse_dates=parse_dates)
y = pd.read_csv("/content/202301-citibike-tripdata_2.csv",dtype=dtypes,parse_dates=parse_dates)
janData = pd.concat([x,y], ignore_index=True)

print("Shape: ", janData.shape)
print("Columns: ", janData.columns.tolist())

janData.head()

# Compute trip duration in minutes
janData['trip_duration_mins'] = (janData['ended_at'] - janData['started_at']).dt.total_seconds()/60

print("Shape: ", janData.shape)

# Filter out unrealistic trips (< 1 min or > 2 hours) and drop missing coordinates
print("Number of Datapoints: ", janData.shape[0])
janData = janData[(janData['trip_duration_mins'] >= 1)]
print("Number of Datapoints: ", janData.shape[0])
janData = janData[(janData['trip_duration_mins'] <= 120)]
print("Number of Datapoints: ", janData.shape[0])

janData = janData.dropna(subset=['start_lat', 'start_lng', 'end_lat', 'end_lng'])
print("Number of Datapoints: ", janData.shape[0])

# Remove the "Lab - NYC" test station
janData = janData[janData['start_station_id'] != 'Lab - NYC']
print("Number of Datapoints: ", janData.shape[0])

# Normalize station IDs to a consistent decimal format
def normalize_station_id(x):
    # Try to interpret as a float if possible
    try:
        num = float(x)
        return f"{num:.2f}"
    except ValueError:
        # If it's alphanumeric, just return as-is (strip whitespace)
        return str(x)

janData['start_station_id'] = janData['start_station_id'].apply(normalize_station_id)
janData['end_station_id']   = janData['end_station_id'].apply(normalize_station_id)

janData.head()

print(janData['rideable_type'].value_counts())
print(janData['member_casual'].value_counts())

# Hourly trip distribution to see commuter peaks
hourCounts = janData["started_at"].dt.hour.value_counts().sort_index()

import matplotlib.pyplot as plt

hourCounts.plot(kind='bar', figsize=(10,4))
plt.title("CitiBike Trips by Hour of Day – Januaruy 2023")
plt.xlabel("Hour of Day")
plt.ylabel("Number of Trips Started")
plt.show()

# Basic dataset statistics
print("Total trip count after pruning:", len(janData))
print("Unique start stations:", janData['start_station_name'].nunique())
print("Unique end stations:", janData['end_station_name'].nunique())
print()
print("Top 10 busiest start stations: ")
print(janData['start_station_name'].value_counts().head(10))
print()
print("Top 10 least busy start stations: ")
print(janData['start_station_name'].value_counts().tail(10))

