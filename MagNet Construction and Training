           .size()
           .reset_index(name="w_uv")
           .rename(columns={"start_station_name":"src", "end_station_name":"dst"})
)

# Drop self-loops
edges = edges[edges["src"] != edges["dst"]].copy()

print("Directed edges:", len(edges))
print("Unique stations:", pd.unique(pd.concat([edges["src"], edges["dst"]])).size)

import numpy as np
import pandas as pd

eps = 1e-9

# Build node index over the full graph
nodes = pd.unique(pd.concat([edges["src"], edges["dst"]]))
nodes = list(nodes)
n = len(nodes)
idx = {s:i for i,s in enumerate(nodes)}

# Merge with swapped columns to get reverse weights for each pair
rev = edges.rename(columns={"src":"dst", "dst":"src", "w_uv":"w_vu"})
pair = edges.merge(rev, on=["src","dst"], how="left")
pair["w_vu"] = pair["w_vu"].fillna(0.0)

# Create canonical unordered pair key to deduplicate
a = pair["src"].map(idx).values
b = pair["dst"].map(idx).values
lo = np.minimum(a,b); hi = np.maximum(a,b)
pair["u"] = lo
pair["v"] = hi

# Collapse to unique unordered pairs with both directional weights
pair_uv = pair.groupby(["u","v"], as_index=False).agg(
    w_ab=("w_uv","max"),   # forward direction
    w_ba=("w_vu","max")    # reverse direction
)

# Symmetric magnitude W and skew orientation T
W = 0.5*(pair_uv["w_ab"].values + pair_uv["w_ba"].values)
T = (pair_uv["w_ab"].values - pair_uv["w_ba"].values) / (pair_uv["w_ab"].values + pair_uv["w_ba"].values + eps)

q = 0.25
Theta = 2*np.pi*q*T

# Construct two directed edges per unordered pair (u->v and v->u with conjugate phases)
u = pair_uv["u"].values.astype(np.int64)
v = pair_uv["v"].values.astype(np.int64)

src = np.concatenate([u, v])
dst = np.concatenate([v, u])

W_dir = np.concatenate([W, W])
Theta_dir = np.concatenate([Theta, -Theta])

# Complex magnetic edge weights (unnormalized)
w_complex = W_dir * (np.cos(Theta_dir) + 1j*np.sin(Theta_dir))

# Magnetic degree from symmetric magnitudes (each unordered pair counted once per node)
d_mag = np.zeros(n, dtype=np.float64)
np.add.at(d_mag, u, W)
np.add.at(d_mag, v, W)

inv_sqrt = 1.0 / np.sqrt(d_mag + 1e-8)

# Normalized complex weights (edgewise D^{-1/2} A_mag D^{-1/2})
w_complex_norm = w_complex * (inv_sqrt[src] * inv_sqrt[dst])

ew_r = np.real(w_complex_norm).astype(np.float32)
ew_i = np.imag(w_complex_norm).astype(np.float32)

print("n =", n, "| undirected pairs =", len(pair_uv), "| directed edges =", len(src))

