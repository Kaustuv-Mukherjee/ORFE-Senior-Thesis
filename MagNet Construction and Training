parse_dates = ["started_at", "ended_at"]

feb_1 = pd.read_csv("/content/202302-citibike-tripdata_1.csv", dtype=dtypes, parse_dates=parse_dates)
feb_2 = pd.read_csv("/content/202302-citibike-tripdata_2.csv", dtype=dtypes, parse_dates=parse_dates)
febData = pd.concat([feb_1, feb_2], ignore_index=True)

febData['trip_duration_mins'] = (febData['ended_at'] - febData['started_at']).dt.total_seconds() / 60
febData = febData[(febData['trip_duration_mins'] >= 1) & (febData['trip_duration_mins'] <= 120)]
febData = febData.dropna(subset=['start_lat', 'start_lng', 'end_lat', 'end_lng'])
febData = febData[febData['start_station_id'] != 'Lab - NYC']
febData = febData[febData['start_station_name'] != febData['end_station_name']]
print("Feb 2023 trips after cleaning:", len(febData))

# Union of Jan and Feb stations defines the shared node universe
jan_edges = (
    janData.groupby(["start_station_name", "end_station_name"])
           .size().reset_index(name="w_uv")
           .rename(columns={"start_station_name": "src", "end_station_name": "dst"})
)
jan_edges = jan_edges[jan_edges["src"] != jan_edges["dst"]].copy()

feb_edges = (
    febData.groupby(["start_station_name", "end_station_name"])
           .size().reset_index(name="w_uv")
           .rename(columns={"start_station_name": "src", "end_station_name": "dst"})
)
feb_edges = feb_edges[feb_edges["src"] != feb_edges["dst"]].copy()

all_stations = pd.unique(pd.concat([jan_edges["src"], jan_edges["dst"],
                                     feb_edges["src"], feb_edges["dst"]]))
nodes_cm = list(all_stations)
n_cm = len(nodes_cm)
idx_cm = {s: i for i, s in enumerate(nodes_cm)}
print(f"Union stations: {n_cm}")

# Build January TRAINING graph: adjacency, W, T, Theta, A_mag
jan_edges["src_i"] = jan_edges["src"].map(idx_cm)
jan_edges["dst_i"] = jan_edges["dst"].map(idx_cm)

A_jan = np.zeros((n_cm, n_cm), dtype=np.float64)
for _, r in jan_edges.iterrows():
    A_jan[int(r["src_i"]), int(r["dst_i"])] = r["w_uv"]

eps = 1e-9
q = 0.25
W_jan = 0.5 * (A_jan + A_jan.T)
T_jan = (A_jan - A_jan.T) / (A_jan + A_jan.T + eps)
Theta_jan = 2 * np.pi * q * T_jan
A_mag_jan = W_jan * np.exp(1j * Theta_jan)

# Normalize magnetic edge weights edgewise
rows_jan, cols_jan = np.nonzero(A_jan > 0)
d_mag_jan = W_jan.sum(axis=1).astype(np.float64)
inv_sqrt_jan = 1.0 / np.sqrt(d_mag_jan + 1e-8)
w_complex_jan = A_mag_jan[rows_jan, cols_jan] * (inv_sqrt_jan[rows_jan] * inv_sqrt_jan[cols_jan])
ewr_jan = np.real(w_complex_jan).astype(np.float32)
ewi_jan = np.imag(w_complex_jan).astype(np.float32)
y_jan = np.log1p(A_jan[rows_jan, cols_jan]).astype(np.float32)

# Build February TEST targets (only edges whose stations appear in Jan node set)
feb_edges["src_i"] = feb_edges["src"].map(idx_cm)
feb_edges["dst_i"] = feb_edges["dst"].map(idx_cm)
feb_edges = feb_edges.dropna(subset=["src_i", "dst_i"])
feb_edges["src_i"] = feb_edges["src_i"].astype(int)
feb_edges["dst_i"] = feb_edges["dst_i"].astype(int)

feb_src = feb_edges["src_i"].values.astype(np.int64)
feb_dst = feb_edges["dst_i"].values.astype(np.int64)
y_feb = np.log1p(feb_edges["w_uv"].values).astype(np.float32)

# Node features from Jan data (in/out deg/str, lat/lng)
out_str = np.zeros(n_cm); in_str = np.zeros(n_cm)
out_deg = np.zeros(n_cm); in_deg = np.zeros(n_cm)
np.add.at(out_str, jan_edges["src_i"].values, jan_edges["w_uv"].values)
