print(f"\nFinal Feb 2023 test correlation: {final_corr:.3f}")

# Training curves and prediction scatter
epochs_ax = np.arange(len(corr_hist)) * 20 + 20

fig, axes = plt.subplots(1, 3, figsize=(16, 4))

axes[0].plot(epochs_ax, train_hist, label="train")
axes[0].plot(epochs_ax, val_hist, label="jan val")
