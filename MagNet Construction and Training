ewi_t = torch.tensor(ewi_obs, dtype=torch.float32, device=device)
y_t   = torch.tensor(y_obs, dtype=torch.float32, device=device)

# Random 80/20 edge-level split
E = y_t.numel()
torch.manual_seed(0)
perm = torch.randperm(E, device=device)
train_E = int(0.8 * E)
train_idx = perm[:train_E]
val_idx   = perm[train_E:]

model = MagNet(in_dim=x_t.size(1), hidden_dim=64, layers=2, dropout=0.15).to(device)
opt = torch.optim.Adam(model.parameters(), lr=1e-3, weight_decay=1e-4)
loss_fn = nn.SmoothL1Loss(beta=1.0)

train_hist = []
val_hist = []
corr_hist = []

# Forward pass on validation edges, returning loss and Pearson correlation
def eval_metrics():
    model.eval()
    with torch.no_grad():
        xr, xi = model(x_t, src_t, dst_t, ewr_t, ewi_t)
        pred = model.predict_edges(xr, xi, src_t[val_idx], dst_t[val_idx])
        loss = loss_fn(pred, y_t[val_idx]).item()
        vp = pred.detach().cpu().numpy()
        vt = y_t[val_idx].detach().cpu().numpy()
        corr = float(np.corrcoef(vp, vt)[0,1])
        return loss, corr, (vp.min(), vp.max()), (vt.min(), vt.max())

# Training loop: 300 epochs of full-batch gradient descent with gradient clipping
for epoch in range(1, 301):
    model.train()
    opt.zero_grad()

    xr, xi = model(x_t, src_t, dst_t, ewr_t, ewi_t)
    pred = model.predict_edges(xr, xi, src_t[train_idx], dst_t[train_idx])
    loss = loss_fn(pred, y_t[train_idx])

    loss.backward()
    torch.nn.utils.clip_grad_norm_(model.parameters(), 2.0)
    opt.step()

    # Every 20 epochs, evaluate on the validation set and log metrics
    if epoch % 20 == 0:
        vloss, vcorr, pr, tr = eval_metrics()
