od = jan_edges.groupby("src_i")["dst_i"].nunique()
id_ = jan_edges.groupby("dst_i")["src_i"].nunique()
out_deg[od.index.values] = od.values
in_deg[id_.index.values] = id_.values

starts = janData[['start_station_name', 'start_lat', 'start_lng']].rename(
    columns={'start_station_name': 'station', 'start_lat': 'lat', 'start_lng': 'lng'})
ends = janData[['end_station_name', 'end_lat', 'end_lng']].rename(
    columns={'end_station_name': 'station', 'end_lat': 'lat', 'end_lng': 'lng'})
coords_cm = (pd.concat([starts, ends], ignore_index=True)
               .dropna(subset=['lat', 'lng'])
               .drop_duplicates(subset=['station'])
               .set_index('station'))

lat = np.array([coords_cm.loc[s, 'lat'] if s in coords_cm.index else np.nan for s in nodes_cm], dtype=float)
lng = np.array([coords_cm.loc[s, 'lng'] if s in coords_cm.index else np.nan for s in nodes_cm], dtype=float)
lat[np.isnan(lat)] = np.nanmean(lat)
lng[np.isnan(lng)] = np.nanmean(lng)

X_cm = np.column_stack([in_deg, out_deg, in_str, out_str, lat, lng]).astype(np.float32)
X_cm = (X_cm - X_cm.mean(axis=0, keepdims=True)) / (X_cm.std(axis=0, keepdims=True) + 1e-6)

# Convert to torch tensors
x_t = torch.tensor(X_cm, dtype=torch.float32, device=device)
src_t = torch.tensor(rows_jan, dtype=torch.long, device=device)
dst_t = torch.tensor(cols_jan, dtype=torch.long, device=device)
ewr_t = torch.tensor(ewr_jan, dtype=torch.float32, device=device)
ewi_t = torch.tensor(ewi_jan, dtype=torch.float32, device=device)
y_t = torch.tensor(y_jan, dtype=torch.float32, device=device)

feb_src_t = torch.tensor(feb_src, dtype=torch.long, device=device)
feb_dst_t = torch.tensor(feb_dst, dtype=torch.long, device=device)
y_feb_t = torch.tensor(y_feb, dtype=torch.float32, device=device)

# Train on January, evaluate on February at each checkpoint
E_jan = len(rows_jan)
torch.manual_seed(0)
perm = torch.randperm(E_jan, device=device)
train_E = int(0.8 * E_jan)
train_idx = perm[:train_E]
val_idx = perm[train_E:]

model = MagNet(in_dim=x_t.size(1), hidden_dim=64, layers=2, dropout=0.15).to(device)
opt = torch.optim.Adam(model.parameters(), lr=1e-3, weight_decay=1e-4)
loss_fn = nn.SmoothL1Loss(beta=1.0)

train_hist = []; val_hist = []; corr_hist = []; feb_corr_hist = []

for epoch in range(1, 301):
    model.train()
    opt.zero_grad()
    xr, xi = model(x_t, src_t, dst_t, ewr_t, ewi_t)
    pred = model.predict_edges(xr, xi, src_t[train_idx], dst_t[train_idx])
    loss = loss_fn(pred, y_t[train_idx])
    loss.backward()
    torch.nn.utils.clip_grad_norm_(model.parameters(), 2.0)
    opt.step()

    if epoch % 20 == 0:
        model.eval()
        with torch.no_grad():
            xr, xi = model(x_t, src_t, dst_t, ewr_t, ewi_t)
            # Jan validation
            vp = model.predict_edges(xr, xi, src_t[val_idx], dst_t[val_idx])
            vl = loss_fn(vp, y_t[val_idx]).item()
            vc = float(np.corrcoef(vp.cpu().numpy(), y_t[val_idx].cpu().numpy())[0, 1])
            # Feb test using Jan embeddings
            fp = model.predict_edges(xr, xi, feb_src_t, feb_dst_t)
            fl = loss_fn(fp, y_feb_t).item()
            fc = float(np.corrcoef(fp.cpu().numpy(), y_feb_t.cpu().numpy())[0, 1])

        train_hist.append(loss.item()); val_hist.append(vl)
        corr_hist.append(vc); feb_corr_hist.append(fc)
