axes[0].legend(); axes[0].set_title("Training Loss")

axes[1].plot(epochs_ax, corr_hist, label="jan val", color="blue")
axes[1].plot(epochs_ax, feb_corr_hist, label="feb test", color="red")
axes[1].set_xlabel("epoch"); axes[1].set_ylabel("correlation")
